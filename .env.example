# Mnemonic — Environment Variables
# Copy to .env and adjust values for your setup.
# cp .env.example .env

# Port the MCP server listens on
MCP_PORT=8080

# Path to the SQLite database file
SQLITE_PATH=./data/memory.db

# Path to the Obsidian vault directory
OBSIDIAN_VAULT=./obsidian-vault

# Qdrant vector store URL
# Leave empty to run in SQLite-only mode (Qdrant not required).
# When Docker Compose starts qdrant internally, the compose service
# uses http://qdrant:6333 — this env var is for external access only.
QDRANT_URL=

# Name of the Qdrant collection for memory records
QDRANT_COLLECTION=memory_records

# Ollama LLM endpoint — reserved for future local-model workflows.
# Not used by current projection logic. Leave empty.
OLLAMA_URL=