# Mnemonic — Environment Variables
# Copy to .env and adjust values for your setup.
# cp .env.example .env

# Port the MCP server listens on
MCP_PORT=8080

# Path to the SQLite database file
SQLITE_PATH=./data/memory.db

# Path to the Obsidian vault directory
OBSIDIAN_VAULT=./obsidian-vault

# Qdrant vector store URL
# Leave empty to run in SQLite-only mode (Qdrant not required).
# When Docker Compose starts qdrant internally, the compose service
# uses http://qdrant:6333 — this env var is for external access only.
QDRANT_URL=

# Name of the Qdrant collection for memory records
QDRANT_COLLECTION=memory_records

# Ollama endpoint for semantic embeddings
# When set, enables Ollama-backed embeddings with automatic hash fallback.
# Example: http://localhost:11434
OLLAMA_URL=

# Embedding strategy: "hash" (deterministic fallback) or "ollama" (semantic)
# Default: hash (always works, no external dependencies)
EMBEDDING_STRATEGY=hash

# Ollama embedding model (used when EMBEDDING_STRATEGY=ollama)
# Default: nomic-embed-text
EMBEDDING_MODEL=nomic-embed-text

# Minimum cosine similarity score for Qdrant vector search hits (0.0 = no filter)
# Increase to reduce false positives; decrease if recall is too low.
SEARCH_SCORE_THRESHOLD=0.5

# Default namespace for new records
DEFAULT_NAMESPACE=default

# Retention action: "delete" or "archive" for expired records
RETENTION_ACTION=delete

# Retention period in days for automatic cleanup
RETENTION_DAYS=30